{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ActionItems.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/ActionItems.Api/bin/Debug/net10.0/ActionItems.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/ActionItems.Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "ActionItems.Worker",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/ActionItems.Worker/bin/Debug/net10.0/ActionItems.Worker.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/ActionItems.Worker",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ],
  "compounds": [
    {
      "name": "API + Worker",
      "configurations": ["ActionItems.Api", "ActionItems.Worker"]
    }
  ]
}
